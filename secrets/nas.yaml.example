# Plain-text structure of secrets/nas.yaml
# ──────────────────────────────────────────────────────────
# The actual secrets/nas.yaml is encrypted with sops and safe to commit.
# This file shows what keys to create — do NOT put real values here.
#
# To create:  sops secrets/nas.yaml
# To edit:    sops secrets/nas.yaml
# To view:    sops -d secrets/nas.yaml

samba:
  antonio_password: "your-samba-password"

vaultwarden:
  admin_token: "your-vaultwarden-admin-token"    # generate: openssl rand -hex 32

ntfy:
  admin_password: "your-ntfy-admin-password"

tailscale:
  auth_key: "tskey-auth-..."                      # from tailscale.com/admin/settings/keys

restic:
  password: "your-restic-repository-password"

gaming_rig_mac: "XX:XX:XX:XX:XX:XX"
