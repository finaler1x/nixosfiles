# Homelab Docker Compose — Environment Variables
# cp .env.example .env  →  then fill in values
# .env is gitignored and must never be committed.

# ── General ───────────────────────────────────────────────
TZ=Europe/Berlin
PUID=1000
PGID=1000

# ── Tailscale ─────────────────────────────────────────────
# Run: tailscale ip -4
TAILSCALE_IP=100.x.x.x

# ── Database (shared PostgreSQL user for Immich + Paperless)
DB_USER=dbadmin
DB_PASSWORD=change_me_secure_password

# ── Immich ────────────────────────────────────────────────
IMMICH_VERSION=release

# ── Paperless-ngx ─────────────────────────────────────────
PAPERLESS_SECRET_KEY=change_me_very_long_random_string_min_50_chars
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=change_me_secure_password
