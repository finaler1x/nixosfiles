# ── Global ────────────────────────────────────────────────
{
  # Use Caddy's internal CA for all sites (no Let's Encrypt needed for .homelab)
  # To trust the CA on your devices, import the root cert from:
  #   docker exec caddy cat /data/caddy/pki/authorities/local/root.crt
  local_certs

  log {
    level WARN
  }
}

# ── Core services ──────────────────────────────────────────

adguard.homelab {
  reverse_proxy adguardhome:3000
}

