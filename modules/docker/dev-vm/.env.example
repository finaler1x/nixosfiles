# dev-vm Docker Compose — Environment Variables
# cp .env.example .env  →  then fill in values
# .env is gitignored and must never be committed.

# ── General ───────────────────────────────────────────────
TZ=Europe/Berlin
PUID=1000
PGID=1000

# ── Code Server ───────────────────────────────────────────
# Plain text password (or use HASHED_PASSWORD instead)
CODE_SERVER_PASSWORD=change_me_secure_password
