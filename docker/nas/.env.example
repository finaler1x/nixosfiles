# NAS Docker Compose — Environment Variables
# cp .env.example .env  →  then fill in values
# .env is gitignored and must never be committed.

# ── General ───────────────────────────────────────────────
TZ=Europe/Berlin
PUID=1000
PGID=1000

# ── VM IPs ────────────────────────────────────────────────
# Fill in after VMs are set up.
# Caddy uses these to route *.home.local → VM services.
# Alternatively add DNS rewrites in AdGuard: service-vm.home.local → IP
SERVICE_VM_IP=192.168.1.XXX
DEV_VM_IP=192.168.1.XXX
